# MongoDB
MONGODB_URI=mongodb://localhost:27017/promocode

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=promocode

# Redis
REDIS_HOST=localhost
